<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema Principal Escuro -->
    <style name="Theme.AgenteAutonomo" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Cores Primárias -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryContainer">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        
        <!-- Cores Secundárias -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>
        
        <!-- Cores de Destaque -->
        <item name="colorTertiary">@color/accent</item>
        <item name="colorTertiaryContainer">@color/accent_light</item>
        <item name="colorOnTertiary">@color/text_primary</item>
        <item name="colorOnTertiaryContainer">@color/text_primary</item>
        
        <!-- Cores de Superfície -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorSurfaceContainer">@color/surface</item>
        <item name="colorSurfaceContainerHigh">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Cores de Fundo -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        
        <!-- Cores de Erro -->
        <item name="colorError">@color/error</item>
        <item name="colorErrorContainer">@color/error</item>
        <item name="colorOnError">@color/text_primary</item>
        <item name="colorOnErrorContainer">@color/text_primary</item>
        
        <!-- Cores de Outline -->
        <item name="colorOutline">@color/border</item>
        <item name="colorOutlineVariant">@color/divider</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        
        <!-- Texto -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_disabled</item>
        
        <!-- Ripple -->
        <item name="colorControlHighlight">@color/ripple</item>
        
        <!-- Action Bar -->
        <item name="actionBarStyle">@style/Widget.AgenteAutonomo.ActionBar</item>
        
        <!-- Toolbar -->
        <item name="toolbarStyle">@style/Widget.AgenteAutonomo.Toolbar</item>
        
        <!-- Card -->
        <item name="materialCardViewStyle">@style/Widget.AgenteAutonomo.CardView</item>
        
        <!-- Button -->
        <item name="materialButtonStyle">@style/Widget.AgenteAutonomo.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.AgenteAutonomo.Button.Outlined</item>
        
        <!-- Input -->
        <item name="textInputStyle">@style/Widget.AgenteAutonomo.TextInput</item>
        
        <!-- Dialog -->
        <item name="materialAlertDialogTheme">@style/Theme.AgenteAutonomo.Dialog</item>
    </style>
    
    <!-- Action Bar Personalizado -->
    <style name="Widget.AgenteAutonomo.ActionBar" parent="Widget.Material3.ActionBar.Solid">
        <item name="background">@color/background</item>
        <item name="titleTextStyle">@style/TextAppearance.AgenteAutonomo.ActionBar.Title</item>
    </style>
    
    <!-- Toolbar Personalizada -->
    <style name="Widget.AgenteAutonomo.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/background</item>
        <item name="titleTextAppearance">@style/TextAppearance.AgenteAutonomo.Toolbar.Title</item>
        <item name="subtitleTextAppearance">@style/TextAppearance.AgenteAutonomo.Toolbar.Subtitle</item>
    </style>
    
    <!-- CardView Personalizado -->
    <style name="Widget.AgenteAutonomo.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="contentPadding">16dp</item>
    </style>
    
    <!-- Botão Primário -->
    <style name="Widget.AgenteAutonomo.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/button_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>
    
    <!-- Botão Outlined -->
    <style name="Widget.AgenteAutonomo.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">8dp</item>
    </style>
    
    <!-- TextInput Personalizado -->
    <style name="Widget.AgenteAutonomo.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_border</item>
        <item name="hintTextColor">@color/input_hint</item>
        <item name="android:textColorHint">@color/input_hint</item>
        <item name="boxBackgroundColor">@color/input_background</item>
        <item name="cornerRadius">8dp</item>
    </style>
    
    <!-- Tema de Diálogo -->
    <style name="Theme.AgenteAutonomo.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:background">@color/surface</item>
    </style>
    
    <!-- Text Appearances -->
    <style name="TextAppearance.AgenteAutonomo.ActionBar.Title" parent="TextAppearance.Material3.ActionBar.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.AgenteAutonomo.Toolbar.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.AgenteAutonomo.Toolbar.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.AgenteAutonomo.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.AgenteAutonomo.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.AgenteAutonomo.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
